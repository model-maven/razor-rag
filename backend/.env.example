# Copy this file to .env and fill in your keys

# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Get from https://app.pinecone.io (API Keys section)
PINECONE_API_KEY=pcsk_...

# You can leave these as-is
PINECONE_INDEX_NAME=pdf-rag-index
EMBEDDING_MODEL=multilingual-e5-large
CLAUDE_MODEL=claude-sonnet-4-6

# Which pipeline to use: plain | langchain | langgraph
RAG_ENGINE=plain

# Optional login for the whole app (leave empty/absent = no login required)
APP_USERNAME=amir
APP_PASSWORD=choose-a-strong-password
